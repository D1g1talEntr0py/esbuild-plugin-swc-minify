{
	"compilerOptions": {
		"strict": true,
		"declaration": true,
		"noImplicitOverride": true,
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"module": "NodeNext",
		"target": "ESNext",
		"lib": [ "ESNext" ],
		"moduleResolution": "NodeNext",
		"outDir": "./dist"
	},
	"include": [ "./src/" ]
}